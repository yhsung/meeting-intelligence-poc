# LLM Provider — choose one: anthropic (default), openai, deepseek, glm
LLM_PROVIDER=anthropic

# Model override (optional — defaults to provider's recommended model)
# anthropic default: claude-sonnet-4-6
# openai default:    gpt-4o-mini
# deepseek default:  deepseek-chat
# glm default:       glm-4-flash
# LLM_MODEL=

# API Keys — only the one matching LLM_PROVIDER is required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GLM_API_KEY=your_glm_api_key_here

# Embedding backend: "openai" or "local" (default: local, uses sentence-transformers)
EMBEDDING_BACKEND=local
